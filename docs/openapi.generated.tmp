      "AssemblyTimeItemResponse": {
        "properties": {
          "id": {
            "type": "integer",
            "title": "Id",
            "description": "记录 ID。"
          },
          "machine_model": {
            "type": "string",
            "title": "Machine Model",
            "description": "机型。"
          },
          "product_series": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Product Series",
            "description": "产品系列。"
          },
          "assembly_name": {
            "type": "string",
            "title": "Assembly Name",
            "description": "部装名称。"
          },
          "assembly_time_days": {
            "type": "number",
            "title": "Assembly Time Days",
            "description": "装配时长（天）。"
          },
          "is_final_assembly": {
            "type": "boolean",
            "title": "Is Final Assembly",
            "description": "是否整机总装。"
          },
          "production_sequence": {
            "type": "integer",
            "title": "Production Sequence",
            "description": "生产顺序。"
          },
          "is_default": {
            "type": "boolean",
            "title": "Is Default",
            "description": "是否默认值。"
          },
          "remark": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Remark",
            "description": "备注。"
          }
        },
        "type": "object",
        "required": [
          "id",
          "machine_model",
          "assembly_name",
          "assembly_time_days",
          "is_final_assembly",
          "production_sequence",
          "is_default"
        ],
        "title": "AssemblyTimeItemResponse",
        "description": "装配时长配置项。"
      },
      "AssemblyTimeRequest": {
        "properties": {
          "machine_model": {
            "type": "string",
            "title": "Machine Model",
            "description": "机型。"
          },
          "product_series": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Product Series",
            "description": "产品系列；可为空。"
          },
          "assembly_name": {
            "type": "string",
            "title": "Assembly Name",
            "description": "部装名称。"
          },
          "assembly_time_days": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "string",
                "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$"
              }
            ],
            "title": "Assembly Time Days",
            "description": "装配时长（天）。"
          },
          "is_final_assembly": {
            "type": "boolean",
            "title": "Is Final Assembly",
            "description": "是否为整机总装。",
            "default": false
          },
          "production_sequence": {
            "type": "integer",
            "title": "Production Sequence",
            "description": "生产顺序，数字越小越靠前。"
          },
          "is_default": {
            "type": "boolean",
            "title": "Is Default",
            "description": "是否为默认时长记录。",
            "default": false
          },
          "remark": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Remark",
            "description": "备注。"
          }
        },
        "type": "object",
        "required": [
          "machine_model",
          "assembly_name",
          "assembly_time_days",
          "production_sequence"
        ],
        "title": "AssemblyTimeRequest",
        "description": "装配时长配置保存请求。",
        "example": {
          "assembly_name": "整机总装",
          "assembly_time_days": 3,
          "is_default": false,
          "is_final_assembly": true,
          "machine_model": "X7-500",
          "plant": "1000",
          "product_series": "X7",
          "production_sequence": 99,
          "remark": "默认总装时长"
        }
      },

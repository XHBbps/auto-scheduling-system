      "PartCycleBaselineRequest": {
        "properties": {
          "id": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Id",
            "description": "记录 ID；编辑已有记录时可传。"
          },
          "part_type": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Part Type",
            "description": "零件类型；为空时会根据其他字段推断。"
          },
          "material_no": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Material No",
            "description": "零件物料号。"
          },
          "material_desc": {
            "type": "string",
            "title": "Material Desc",
            "description": "零件物料描述。"
          },
          "core_part_name": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Core Part Name",
            "description": "核心零件名称。"
          },
          "machine_model": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Machine Model",
            "description": "机型；零件周期基准按机型维度维护。"
          },
          "plant": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Plant",
            "description": "工厂；为空时表示该机型下的通用工厂基准。"
          },
          "ref_batch_qty": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "string",
                "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$"
              }
            ],
            "title": "Ref Batch Qty",
            "description": "参考批量。"
          },
          "cycle_days": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "string",
                "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$"
              }
            ],
            "title": "Cycle Days",
            "description": "批量周期（天）。"
          },
          "unit_cycle_days": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "string",
                "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$"
              }
            ],
            "title": "Unit Cycle Days",
            "description": "单位周期（天/件）。"
          },
          "cycle_source": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Cycle Source",
            "description": "周期来源。"
          },
          "match_rule": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Match Rule",
            "description": "匹配规则说明。"
          },
          "confidence_level": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Confidence Level",
            "description": "可信度等级。"
          },
          "is_default": {
            "type": "boolean",
            "title": "Is Default",
            "description": "是否为默认基准。",
            "default": false
          },
          "is_active": {
            "type": "boolean",
            "title": "Is Active",
            "description": "是否启用该基准。",
            "default": true
          },
          "remark": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Remark",
            "description": "备注。"
          }
        },
        "type": "object",
        "required": [
          "material_desc",
          "ref_batch_qty",
          "cycle_days",
          "unit_cycle_days"
        ],
        "title": "PartCycleBaselineRequest",
        "description": "零件周期基准保存请求。",
        "example": {
          "confidence_level": "high",
          "cycle_days": 12,
          "cycle_source": "manual",
          "is_active": true,
          "is_default": false,
          "machine_model": "X7-500",
          "match_rule": "机型 + 工厂 + 零件类型",
          "material_desc": "车架总成",
          "part_type": "车架",
          "plant": "1000",
          "ref_batch_qty": 10,
          "remark": "首版人工维护",
          "unit_cycle_days": 1.2
        }
      },

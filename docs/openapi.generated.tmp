      "MachineCycleBaselineRequest": {
        "properties": {
          "product_series": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Product Series",
            "description": "产品系列；可为空。"
          },
          "machine_model": {
            "type": "string",
            "title": "Machine Model",
            "description": "机型。"
          },
          "order_qty": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "string",
                "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$"
              }
            ],
            "title": "Order Qty",
            "description": "订单数量分档。"
          },
          "cycle_days_median": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "string",
                "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$"
              }
            ],
            "title": "Cycle Days Median",
            "description": "该数量分档对应的整机周期中位数（天）。"
          },
          "sample_count": {
            "type": "integer",
            "title": "Sample Count",
            "description": "用于生成该基准的样本数量。",
            "default": 0
          },
          "is_active": {
            "type": "boolean",
            "title": "Is Active",
            "description": "是否启用该基准。",
            "default": true
          },
          "remark": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Remark",
            "description": "备注。"
          }
        },
        "type": "object",
        "required": [
          "machine_model",
          "order_qty",
          "cycle_days_median"
        ],
        "title": "MachineCycleBaselineRequest",
        "description": "整机周期基准保存请求。",
        "example": {
          "cycle_days_median": 45,
          "is_active": true,
          "machine_model": "X7-500",
          "order_qty": 1,
          "plant": "1000",
          "product_series": "X7",
          "remark": "人工校准基准",
          "sample_count": 12
        }
      },

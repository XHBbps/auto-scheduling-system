{
  "name": "auto-scheduling-system-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && node --require ./scripts/patch-vite-windows-exec.cjs ./node_modules/vite/bin/vite.js build",
    "lint": "eslint . --ext .js,.ts,.vue --max-warnings 0",
    "preview": "vite preview",
    "test": "node --require ./scripts/patch-vite-windows-exec.cjs ./node_modules/vitest/vitest.mjs run",
    "analyze:chunks": "node ./scripts/report-build-chunks.cjs",
    "build:observe": "npm run build && npm run analyze:chunks"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "axios": "^1.13.6",
    "echarts": "^6.0.0",
    "element-plus": "^2.13.5",
    "vue": "^3.5.30",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^10.1.0",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.2",
    "vite": "^8.0.0",
    "vitest": "^4.1.1",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.5"
  }
}

# =========================================================
# 自动排产系统本地联调配置模板
# 说明：
# 1. 复制本文件为 .env 并填入真实值
# 2. .env 文件不可提交到版本库
# =========================================================

# -------------------------
# 数据库
# -------------------------
DATABASE_URL=postgresql+asyncpg://postgres:your_password_here@127.0.0.1:5432/auto_scheduling?ssl=disable
ADMIN_API_TOKEN=
BOOTSTRAP_ADMIN_PASSWORD=

# -------------------------
# 观远 BI（销售计划同步）
# -------------------------
GUANDATA_BASE_URL=http://guandata.yangli.com:8066
GUANDATA_DOMAIN=guanbi
GUANDATA_LOGIN_ID=
GUANDATA_PASSWORD=
GUANDATA_DS_ID=

# -------------------------
# SAP BOM
# -------------------------
SAP_BOM_BASE_URL=

# -------------------------
# 飞书应用（生产订单 / 研究所）
# -------------------------
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_PRODUCTION_APP_TOKEN=
FEISHU_PRODUCTION_TABLE_ID=
FEISHU_RESEARCH_APP_TOKEN=
FEISHU_RESEARCH_TABLE_ID=

# -------------------------
# 排产参数
# -------------------------
SCHEDULE_TRIGGER_ADVANCE_DAYS=28

# -------------------------
# 定时同步（当前默认关闭）
# -------------------------
SYNC_SCHEDULER_ENABLED=false
SYNC_SCHEDULER_TIMEZONE=Asia/Shanghai
SALES_PLAN_SYNC_HOUR=6
SALES_PLAN_SYNC_MINUTE=0
BOM_SYNC_HOUR=6
BOM_SYNC_MINUTE=30
PRODUCTION_ORDER_SYNC_HOUR=7
PRODUCTION_ORDER_SYNC_MINUTE=0
RESEARCH_SYNC_HOUR=7
RESEARCH_SYNC_MINUTE=30
